# halseth — environment schema (Cloudflare Worker)
# @defaultSensitive=true @defaultRequired=false
#
# Secrets here are set in production via `wrangler secret put <KEY>` and locally
# via `.dev.vars` (gitignored). All are optional in lean phase: each gracefully
# no-ops or falls back to a default when unset.
#
# NOTE: non-secret runtime flags (PLURALITY_ENABLED, COMPANIONS_ENABLED,
# COORDINATION_ENABLED, SYSTEM_NAME, SYSTEM_OWNER, COMPANION_TOOLS_DEFAULT) live
# in wrangler.toml [vars] (committed, public) — not here. Cloudflare BINDINGS
# (DB/D1, BUCKET/R2, AI, VECTORIZE, LIBRARIAN_KV, PLURAL service, RATE_LIMITER)
# are wrangler bindings, not env vars.

# --- Auth secrets ---

# Protects POST /admin/bootstrap (seed config, companions, wounds). Also the
# shared secret the Discord bots + Second Brain present as HALSETH_SECRET.
# @type=string @sensitive
ADMIN_SECRET=

# Protects POST /librarian. Auth skipped entirely if unset (lean phase).
# @type=string @sensitive
MCP_AUTH_SECRET=

# Per-companion bearer tokens (opt-in; ASI07). Recognized by the central authGuard.
# @type=string @sensitive
CYPHER_MCP_SECRET=

# @type=string @sensitive
DREVAN_MCP_SECRET=

# @type=string @sensitive
GAIA_MCP_SECRET=

# OAuth token for the Second Brain backend (mcp.example.com) via Librarian.
# @type=string @sensitive
SECOND_BRAIN_TOKEN=

# --- Provider / external API keys ---

# DeepSeek V3 — KV pattern classification in the Librarian router.
# @type=string @sensitive
DEEPSEEK_API_KEY=

# Tavily — companion web-search tool layer (migration 0077).
# @type=string @sensitive
TAVILY_API_KEY=

# Google Gemini — image generation (migration 0077). `imagine` no-ops until set.
# @type=string @sensitive
GEMINI_API_KEY=

# Anthropic Claude — weekly clearing-pass + drift-pass + emergent-SOMA. No-ops if unset.
# @type=string @sensitive
ANTHROPIC_API_KEY=

# Cross-instance bridge shared symmetric secret — must match partner Halseth.
# @type=string @sensitive
BRIDGE_SECRET=

# --- Non-secret URLs ---

# Second Brain HTTP base URL for session-close webhooks (e.g. https://mcp.example.com).
# @type=url @sensitive=false
SECOND_BRAIN_WEBHOOK_URL=

# Partner Halseth base URL for cross-instance sharing; bridge disabled if empty.
# @type=url @sensitive=false
BRIDGE_URL=

# This worker's public base URL, for building /mind/tools/image/:id links.
# @type=url @sensitive=false
PUBLIC_BASE_URL=

# --- Non-secret model / tuning overrides (optional; have code defaults) ---

# @type=string @sensitive=false
CLEARING_MODEL=

# @type=number @sensitive=false
CLEARING_MAX=

# @type=string @sensitive=false
DRIFT_MODEL=

# @type=number @sensitive=false
DRIFT_MAX=

# @type=string @sensitive=false
SOMA_SHIFT_MODEL=

# Max |delta| a single crystallize may shift a SOMA float (default 0.03; ceiling 0.08).
# @type=number @sensitive=false
SOMA_SHIFT_MAX=

# @type=string @sensitive=false
GEMINI_IMAGE_MODEL=

# Tools-gate fallback when no per-companion setting exists (default false).
# @type=boolean @sensitive=false
COMPANION_TOOLS_DEFAULT=
