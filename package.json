{
  "name": "halseth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --config wrangler.prod.toml",
    "deploy": "wrangler deploy --config wrangler.prod.toml",
    "migrate:local": "wrangler d1 migrations apply halseth --local --config wrangler.prod.toml",
    "migrate:remote": "wrangler d1 migrations apply halseth --remote --config wrangler.prod.toml",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260403.1",
    "typescript": "5.9.3",
    "vitest": "4.1.2",
    "wrangler": "4.80.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "fetch-to-node": "2.1.0",
    "zod": "4.3.6"
  }
}
