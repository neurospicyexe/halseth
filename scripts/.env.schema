# Autonomous time scripts — environment schema
# @defaultSensitive=true

# Base URL of the deployed Halseth Cloudflare Worker
# Example: https://halseth.your-subdomain.workers.dev
# @type=url @sensitive=false @required
HALSETH_URL=

# Shared secret for Halseth API auth (matches ADMIN_SECRET on the worker)
# @type=string @sensitive @required
HALSETH_SECRET=
